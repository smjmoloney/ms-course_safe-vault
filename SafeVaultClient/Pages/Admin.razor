@page "/admin"

<PageTitle>Admin</PageTitle>

<h1>Admin — Add User</h1>

<div class="mb-3">
    <label class="form-label">Username</label>
    <input class="form-control" @bind="username" placeholder="Enter username" />
</div>

<div class="mb-3">
    <label class="form-label">Password</label>
    <input class="form-control" type="password" @bind="password" placeholder="Enter password" />
</div>

<button class="btn btn-primary" @onclick="HandleInsert">Insert User</button>

@if (message is not null)
{
    <p class="mt-3 @messageClass">@message</p>
}

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private string? message;
    private string messageClass = string.Empty;

    private async Task HandleInsert()
    {
        var response = await Http.PostAsJsonAsync("api/users", new { username, password });

        if (response.IsSuccessStatusCode)
        {
            message = "User inserted successfully.";
            messageClass = "text-success";
            username = string.Empty;
            password = string.Empty;
        }
        else
        {
            message = "Failed to insert user. Check that inputs are valid.";
            messageClass = "text-danger";
        }
    }

    [Inject] private HttpClient Http { get; set; } = default!;
}
