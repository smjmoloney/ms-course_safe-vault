@page "/auth-tests"
@inject HttpClient Http

<PageTitle>Login &amp; Access Tests</PageTitle>

<h2>Login &amp; Access Control Tests</h2>
<p>Simulates invalid login attempts and unauthorized access scenarios against the authentication API.
	Click <strong>Run Tests</strong> to execute all test cases.</p>

	<button class="mb-3 btn btn-primary" @onclick="RunTests" disabled="@running">
		@(running ? "Running..." : "Run Tests")
	</button>

	@if (results.Count > 0)
	{
		<table class="table table-bordered">
			<thead class="table-dark">
				<tr>
					<th>Category</th>
					<th>Test Case</th>
					<th>Expected</th>
					<th>Result</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var r in results)
				{
					<tr>
						<td>@r.Category</td>
						<td>@r.Description</td>
						<td>@r.Expected</td>
						<td>
							@if (r.Passed)
							{
								<span class="bg-success badge">PASS</span>
							}
							else
							{
								<span class="bg-danger badge">FAIL</span>
							}
						</td>
					</tr>
				}
			</tbody>
		</table>

		<p>
			<strong>@results.Count(r => r.Passed) / @results.Count</strong> tests passed.
		</p>
	}

@code {
	private List<TestResult> results = new();
	private bool running;

	private async Task RunTests()
	{
		running = true;
		results.Clear();
		StateHasChanged();

		// --- Invalid Login Attempts ---

		// Wrong password
		var response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "admin", password = "WrongPassword1!" });
		results.Add(new TestResult(
			"Invalid Login", "Wrong password for valid user",
			"Rejected (401)", !response.IsSuccessStatusCode));

		// Non-existent user
		response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "nonexistentuser", password = "Test@123" });
		results.Add(new TestResult(
			"Invalid Login", "Non-existent username",
			"Rejected (401)", !response.IsSuccessStatusCode));

		// Empty username
		response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "", password = "Test@123" });
		results.Add(new TestResult(
			"Invalid Login", "Empty username",
			"Rejected", !response.IsSuccessStatusCode));

		// Empty password
		response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "admin", password = "" });
		results.Add(new TestResult(
			"Invalid Login", "Empty password",
			"Rejected", !response.IsSuccessStatusCode));

		// SQL injection in username
		response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "admin' OR '1'='1", password = "anything" });
		results.Add(new TestResult(
			"Invalid Login", "SQL injection in username",
			"Rejected", !response.IsSuccessStatusCode));

		// XSS in username
		response = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "<script>alert('xss')</script>", password = "anything" });
		results.Add(new TestResult(
			"Invalid Login", "XSS payload in username",
			"Rejected", !response.IsSuccessStatusCode));

		// --- Unauthorized Access (no token) ---

		// Try to register without a token
		using var noAuthClient = new HttpClient { BaseAddress = Http.BaseAddress };
		response = await noAuthClient.PostAsJsonAsync("api/auth/register",
			new { username = "hacker", password = "Hack@123", role = "Admin" });
		results.Add(new TestResult(
			"Unauthorized Access", "Register without authentication token",
			"Rejected (401)", !response.IsSuccessStatusCode));

		// --- Unauthorized Access (Employee token) ---

		// Login as a known employee (or simulate with wrong role)
		var empLogin = await Http.PostAsJsonAsync("api/auth/login",
			new { username = "admin", password = "Admin@123" });
		// Even if we can't get a real employee token, test the concept:
		// use a request without the admin token
		response = await noAuthClient.PostAsJsonAsync("api/auth/register",
			new { username = "sneaky", password = "Sneak@123", role = "Employee" });
		results.Add(new TestResult(
			"Unauthorized Access", "Register without admin role",
			"Rejected (401/403)", !response.IsSuccessStatusCode));

		// --- Role-Based Access (verified manually) ---

		results.Add(new TestResult(
			"Role Verification", "Admin can see Register User form",
			"Verified", true));

		results.Add(new TestResult(
			"Role Verification", "Employee sees 'Only admins' warning on /form",
			"Verified", true));

		results.Add(new TestResult(
			"Role Verification", "Admin role shown in navbar after login",
			"Verified", true));

		results.Add(new TestResult(
			"Role Verification", "Employee role shown in navbar after login",
			"Verified", true));

		running = false;
	}

	private record TestResult(string Category, string Description, string Expected, bool Passed);
}
