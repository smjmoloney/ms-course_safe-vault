@page "/form"
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Manual Tests</PageTitle>

<h1>Manual Tests</h1>

<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="mt-1 row g-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Register User (Admin)</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input class="form-control" @bind="insertUsername" placeholder="Enter username" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input class="form-control" type="password" @bind="insertPassword"
                                   placeholder="Enter password" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select class="form-select" @bind="insertRole">
                                <option value="Employee">Employee</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <button class="btn btn-primary" @onclick="HandleInsert">Register User</button>
                        @if (insertMessage is not null)
                        {
                            <p class="mt-3 @insertMessageClass">@insertMessage</p>
                        }
                        @if (passwordHash is not null)
                        {
                            <div class="mt-3 alert alert-info">
                                <strong>Password Hash Verification</strong><br />
                                <small>This user's hashed password is:</small>
                                <code class="d-block mt-1" style="word-break: break-all;">@passwordHash</code>
                                <small class="d-block mt-1 text-muted">The plaintext password is never stored. Identity uses PBKDF2 hashing by default.</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="mt-3 alert alert-warning">Only admins can register users.</div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string insertUsername = string.Empty;
    private string insertPassword = string.Empty;
    private string insertRole = "Employee";
    private string? insertMessage;
    private string insertMessageClass = string.Empty;
    private string? passwordHash;

    private async Task HandleInsert()
    {
        passwordHash = null;
        var response = await Http.PostAsJsonAsync("api/auth/register",
            new { username = insertUsername, password = insertPassword, role = insertRole });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<RegisterResponse>();
            insertMessage = result?.Message ?? "Registered successfully.";
            insertMessageClass = "text-success";
            passwordHash = result?.PasswordHash;
            insertUsername = string.Empty;
            insertPassword = string.Empty;
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            insertMessage = $"Failed: {error}";
            insertMessageClass = "text-danger";
        }
    }

    private record RegisterResponse(string Message, string PasswordHash);
}